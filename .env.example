DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional pricing overrides (GBP per million tokens). Defaults live in sim/lib/llm.ts.
# VERIFY pricing before launch (build-spec §7).
DS_RATE_IN_MISS=
DS_RATE_IN_HIT=
DS_RATE_OUT=

# Supabase (project: WidgetCo, eu-central-2).
# - The PUBLISHABLE key is safe to expose (we don't currently use it: visitors
#   never talk to Supabase directly; everything goes through our API routes).
# - The SECRET key (sb_secret_...) is used by the sim's sync step and the web
#   API routes ONLY — never in the browser, never committed. In production it
#   lives in GitHub Actions secrets and Vercel env vars.
SUPABASE_URL=https://ywfevamxqwqoktgrjjvp.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_V1NQ-Qp-_hLjGg3gMVKjYw_DxP8UiZj
SUPABASE_SECRET_KEY=
